"""
FastAPI application for PDF Upload, Extraction, and Combined HTML Export Tool.
Main entry point for the backend service.
"""

import os
import shutil
from datetime import datetime
from pathlib import Path
from typing import List, Optional

from fastapi import FastAPI, File, HTTPException, UploadFile, status
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse
from pydantic import BaseModel

from .extractor import PDFExtractor, ExtractionResult
from .file_service import FileService
from .html_writer import HTMLWriter

# Initialize FastAPI app
app = FastAPI(
    title="PDF Extraction Service",
    description="Backend service for uploading PDFs, extracting text, and generating combined HTML output",
    version="1.0.0"
)

# Configure CORS for frontend communication
app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Initialize services
file_service = FileService()
extractor = PDFExtractor()
html_writer = HTMLWriter()


# Pydantic models for request/response
class UploadResponse(BaseModel):
    """Response model for file uploads."""
    message: str
    uploaded_files: List[str]
    skipped_files: List[str] = []
    errors: List[str] = []


class FileInfo(BaseModel):
    """Model for file information."""
    filename: str
    size_bytes: int
    modified_time: str


class ProcessRequest(BaseModel):
    """Request model for triggering processing."""
    overwrite_existing: bool = False
    sort_order: str = "asc"  # "asc" or "desc"


class ProcessResult(BaseModel):
    """Model for individual PDF extraction result."""
    filename: str
    success: bool
    page_count: int = 0
    text_length: int = 0
    error: Optional[str] = None


class ProcessResponse(BaseModel):
    """Response model for processing endpoint."""
    message: str
    timestamp: str
    output_filename: str
    output_path: str
    total_files: int
    successful_extractions: int
    failed_extractions: int
    results: List[ProcessResult]
    html_preview: Optional[str] = None


class ResultFileInfo(BaseModel):
    """Model for generated HTML file information."""
    filename: str
    path: str
    size_bytes: int
    created_time: str
    download_url: str


@app.get("/")
async def root():
    """Health check endpoint."""
    return {
        "service": "PDF Extraction Service",
        "version": "1.0.0",
        "status": "running",
        "endpoints": [
            {"path": "/upload", "method": "POST", "description": "Upload PDF files"},
            {"path": "/files", "method": "GET", "description": "List uploaded PDFs"},
            {"path": "/process", "method": "POST", "description": "Process all PDFs and generate HTML"},
            {"path": "/results", "method": "GET", "description": "List generated HTML files"},
            {"path": "/health", "method": "GET", "description": "Service health check"}
        ]
    }


@app.get("/health")
async def health_check():
    """Health check endpoint with service status."""
    try:
        # Check if required directories exist or can be created
        file_service.ensure_directories()
        return {
            "status": "healthy",
            "timestamp": datetime.now().isoformat(),
            "directories": {
                "sourcedocs": str(file_service.source_dir),
                "destination": str(file_service.dest_dir)
            }
        }
    except Exception as e:
        raise HTTPException(
            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,
            detail=f"Service unhealthy: {str(e)}"
        )


@app.post("/upload", response_model=UploadResponse)
async def upload_files(files: List[UploadFile] = File(...)):
