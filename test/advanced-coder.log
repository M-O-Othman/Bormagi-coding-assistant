  "content": "\"\"\"\nFile service module for handling file operations in the PDF extraction system.\nManages uploaded PDF files in /sourcedocs and generated HTML files in /destination.\n\"\"\"\n\nimport os\nimport shutil\nfrom pathlib import Path\nfrom typing import List, Optional\nfrom fastapi import UploadFile, HTTPException\n\n\nclass FileService:\n    \"\"\"Service for managing files in the PDF extraction system.\"\"\"\n    \n    def __init__(self, base_dir: Optional[Path] = None):\n        \"\"\"\n        Initialize the file service.\n        \n        Args:\n            base_dir: Base directory for the application. If None, uses current working directory.\n        \"\"\"\n        if base_dir is None:\n            base_dir = Path.cwd()\n        \n        self.base_dir = base_dir\n        self.source_dir = base_dir / \"sourcedocs\"\n        self.dest_dir = base_dir / \"destination\"\n    \n    def ensure_directories(self) -> None:\n        \"\"\"\n        Ensure that required directories exist.\n        Creates /sourcedocs and /destination if they don't exist.\n        \"\"\"\n        try:\n            self.source_dir.mkdir(parents=True, exist_ok=True)\n            self.dest_dir.mkdir(parents=True, exist_ok=True)\n        except Exception as e:\n            raise HTTPException(\n                status_code=500,\n                detail=f\"Failed to create required directories: {str(e)}\"\n            )\n    \n    async def save_uploaded_file(self, file: UploadFile) -> Path:\n        \"\"\"\n        Save an uploaded PDF file to the source directory.\n        \n        Args:\n            file: UploadFile object from FastAPI\n            \n        Returns:\n            Path to the saved file\n            \n        Raises:\n            HTTPException: If file is not a PDF or cannot be saved\n        \"\"\"\n        # Validate file extension\n        if not file.filename.lower().endswith('.pdf'):\n            raise HTTPException(\n                status_code=400,\n                detail=f\"File '{file.filename}' is not a PDF file\"\n            )\n        \n        # Ensure directories exist\n        self.ensure_directories()\n        \n        # Create safe filename (prevent path traversal)\n        safe_filename = self._make_safe_filename(file.filename)\n        file_path = self.source_dir / safe_filename\n        \n        try:\n            # Save the uploaded file\n            with open(file_path, \"wb\") as buffer:\n                # Read file in chunks to handle large files\n                content = await file.read()\n                buffer.write(content)\n            \n            # Reset file pointer for potential reuse\n            await file.seek(0)\n            \n            return file_path\n            \n        except Exception as e:\n            # Clean up partially written file if it exists\n            if file_path.exists():\n                try:\n                    file_path.unlink()\n                except:\n                    pass\n            \n            raise HTTPException(\n                status_code=500,\n                detail=f\"Failed to save file '{file.filename}': {str(e)}\"\n            )\n    \n    def list_pdf_files(self, sort_ascending: bool = True) -> List[Path]:\n        \"\"\"\n        List all PDF files in the source directory.\n        \n        Args:\n            sort_ascending: If True, sort by filename ascending (case-insensitive)\n            \n        Returns:\n            List of Path objects for PDF files\n        \"\"\"\n        self.ensure_directories()\n        \n        # Find all PDF files\n        pdf_files = list(self.source_dir.glob(\"*.pdf\"))\n        \n        # Sort files\n        if sort_ascending:\n            pdf_files.sort(key=lambda p: p.name.lower())\n        else:\n            pdf_files.sort(key=lambda p: p.name.lower(), reverse=True)\n        \n        return pdf_files\n    \n    def get_pdf_files_count(self) -> int:\n        \"\"\"Get the number of PDF files in the source directory.\"\"\"\n        return len(self.list_pdf_files())\n    \n    def get_file_info(self, file_path: Path) -> dict:\n        \"\"\"\n        Get information about a file.\n      … [9415 chars total]"
