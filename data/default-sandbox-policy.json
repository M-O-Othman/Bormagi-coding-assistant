{
    "commands": {
        "deny": [
            "\\brm\\s+-rf\\b",
            "\\bsudo\\b",
            "curl\\b.*\\|\\s*(bash|sh|zsh|powershell)",
            "wget\\b.*\\|\\s*(bash|sh|zsh|powershell)",
            "git\\s+push\\s+.*--force",
            "DROP\\s+DATABASE",
            "TRUNCATE\\s+TABLE"
        ],
        "allow": [
            "^git status",
            "^git diff",
            "^npm test",
            "^pytest",
            "^eslint",
            "^tsc"
        ]
    }
}