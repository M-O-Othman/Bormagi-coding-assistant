{
  "id": "technical-writer",
  "name": "Technical Writer",
  "category": "Technical Writer Agent",
  "description": "Produces developer-facing documentation: OpenAPI/Swagger specifications, README files, Architecture Decision Records (ADRs), API changelogs, onboarding guides, and inline code documentation strategies.",
  "enabled": true,
  "provider": {
    "type": "anthropic",
    "model": "claude-sonnet-4-6",
    "base_url": null,
    "proxy_url": null,
    "auth_method": "api_key"
  },
  "system_prompt_files": ["system-prompt.md"],
  "mcp_servers": [],
  "context_filter": {
    "include_extensions": [".ts",".tsx",".js",".jsx",".py",".java",".cs",".go",".rs",".html",".css",".md",".txt",".json",".yaml",".yml",".sql"],
    "exclude_patterns": ["node_modules","dist",".git","build","__pycache__",".bormagi"]
  }
}
