{
  "name": "bormagi",
  "displayName": "Bormagi",
  "description": "AI coding agent manager — create, configure, and chat with named agents powered by your choice of LLM.",
  "version": "0.1.0",
  "publisher": "MO-Othman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bormagi/bormagi-extension"
  },
  "homepage": "https://github.com/bormagi/bormagi-extension#readme",
  "bugs": {
    "url": "https://github.com/bormagi/bormagi-extension/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "copilot",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "mcp"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bormagi",
          "title": "Bormagi",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "bormagi": [
        {
          "type": "webview",
          "id": "bormagi.chatView",
          "name": "Chat",
          "retainContextWhenHidden": true
        }
      ]
    },
    "commands": [
      {
        "command": "bormagi.initialiseWorkspace",
        "title": "Bormagi: Initialise Workspace",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.openSettings",
        "title": "Bormagi: Open Agent Settings",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.newAgent",
        "title": "Bormagi: Create New Agent",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.installPredefinedAgents",
        "title": "Bormagi: Install Predefined Agents",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.openChat",
        "title": "Bormagi: Open Chat",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.selectAgent",
        "title": "Bormagi: Select Active Agent",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.showAuditLog",
        "title": "Bormagi: Show Audit Log",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.verifyAuditLog",
        "title": "Bormagi: Verify Audit Log Integrity",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.openDashboard",
        "title": "Bormagi: Open Dashboard",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.startMeeting",
        "title": "Bormagi: Start Virtual Meeting",
        "category": "Bormagi"
      }
    ],
    "configuration": {
      "title": "Bormagi",
      "properties": {
        "bormagi.defaultModel.openai": {
          "type": "string",
          "default": "gpt-5.1",
          "description": "Default model for OpenAI provider."
        },
        "bormagi.defaultModel.anthropic": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Default model for Anthropic provider."
        },
        "bormagi.defaultModel.gemini": {
          "type": "string",
          "default": "gemini-2.5-pro",
          "description": "Default model for Google Gemini provider."
        },
        "bormagi.defaultModel.deepseek": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Default model for Deepseek provider."
        },
        "bormagi.defaultModel.qwen": {
          "type": "string",
          "default": "qwen-max",
          "description": "Default model for Qwen provider."
        },
        "bormagi.contextMaxFiles": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of workspace files to include in agent context."
        },
        "bormagi.contextMaxFileSizeKb": {
          "type": "number",
          "default": 100,
          "description": "Maximum size (KB) of a single file to include in context."
        },
        "bormagi.showThoughtTrace": {
          "type": "boolean",
          "default": true,
          "description": "Show agent thought trace (tool calls and reasoning) in the chat view."
        },
        "bormagi.defaultProvider.type": {
          "type": "string",
          "enum": [
            "openai",
            "anthropic",
            "gemini",
            "deepseek",
            "qwen"
          ],
          "default": "anthropic",
          "description": "Default LLM provider used when an agent has no provider configured."
        },
        "bormagi.defaultProvider.model": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Default model for the default provider."
        },
        "bormagi.defaultProvider.authMethod": {
          "type": "string",
          "enum": [
            "api_key",
            "oauth_proxy",
            "vertex_ai"
          ],
          "default": "api_key",
          "description": "Default auth method for the default provider."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "bormagi.initialiseWorkspace",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.openSettings",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.newAgent",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.installPredefinedAgents",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.selectAgent",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.showAuditLog",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.verifyAuditLog",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.openDashboard",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.startMeeting",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npx webpack",
    "watch": "npx webpack --watch",
    "package": "node ./node_modules/webpack/bin/webpack.js --mode production --devtool hidden-source-map",
    "pretest": "npm run lint",
    "lint": "eslint src",
    "test": "npx jest",
    "vsce:package": "npx @vscode/vsce package",
    "vsce:publish": "npx @vscode/vsce publish",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.9.1",
    "jest": "^30.2.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@google/generative-ai": "^0.21.0",
    "docx": "^8.5.0",
    "openai": "^4.67.3",
    "pptxgenjs": "^3.12.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  }
}
