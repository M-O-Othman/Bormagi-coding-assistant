{
  "name": "bormagi",
  "displayName": "Bormagi",
  "description": "AI coding agent manager — create, configure, and chat with named agents powered by your choice of LLM.",
  "version": "0.1.0",
  "publisher": "bormagi",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "copilot",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "mcp"
  ],
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bormagi",
          "title": "Bormagi",
          "icon": "media/bormagi-icon.svg"
        }
      ]
    },
    "views": {
      "bormagi": [
        {
          "type": "webview",
          "id": "bormagi.chatView",
          "name": "Chat",
          "retainContextWhenHidden": true
        }
      ]
    },
    "commands": [
      {
        "command": "bormagi.initialiseWorkspace",
        "title": "Bormagi: Initialise Workspace",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.openSettings",
        "title": "Bormagi: Open Agent Settings",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.newAgent",
        "title": "Bormagi: Create New Agent",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.installPredefinedAgents",
        "title": "Bormagi: Install Predefined Agents",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.openChat",
        "title": "Bormagi: Open Chat",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.selectAgent",
        "title": "Bormagi: Select Active Agent",
        "category": "Bormagi"
      },
      {
        "command": "bormagi.showAuditLog",
        "title": "Bormagi: Show Audit Log",
        "category": "Bormagi"
      }
    ],
    "configuration": {
      "title": "Bormagi",
      "properties": {
        "bormagi.defaultModel.openai": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default model for OpenAI provider."
        },
        "bormagi.defaultModel.anthropic": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Default model for Anthropic provider."
        },
        "bormagi.defaultModel.gemini": {
          "type": "string",
          "default": "gemini-1.5-pro",
          "description": "Default model for Google Gemini provider."
        },
        "bormagi.defaultModel.deepseek": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Default model for Deepseek provider."
        },
        "bormagi.defaultModel.qwen": {
          "type": "string",
          "default": "qwen-max",
          "description": "Default model for Qwen provider."
        },
        "bormagi.contextMaxFiles": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of workspace files to include in agent context."
        },
        "bormagi.contextMaxFileSizeKb": {
          "type": "number",
          "default": 100,
          "description": "Maximum size (KB) of a single file to include in context."
        },
        "bormagi.showThoughtTrace": {
          "type": "boolean",
          "default": true,
          "description": "Show agent thought trace (tool calls and reasoning) in the chat view."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "bormagi.initialiseWorkspace",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.openSettings",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.newAgent",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.installPredefinedAgents",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.selectAgent",
          "when": "workspaceFolderCount > 0"
        },
        {
          "command": "bormagi.showAuditLog",
          "when": "workspaceFolderCount > 0"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.9.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@google/generative-ai": "^0.21.0",
    "openai": "^4.67.3"
  }
}
