{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "process",
      "command": "node",
      "args": ["${workspaceFolder}/node_modules/webpack/bin/webpack.js"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": "$ts-webpack"
    }
  ]
}
